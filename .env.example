MYSQL_DATABASE=campus_service
MYSQL_USER=campus
MYSQL_PASSWORD=campus_pwd
MYSQL_ROOT_PASSWORD=root_pwd

SPRING_PROFILES_ACTIVE=prod
SQL_MIGRATION_ENABLED=true

BACKEND_PORT=8080
NGINX_PORT=80
NGINX_HTML_DIR=./deploy/html
MYSQL_PORT=3306
REDIS_PORT=6379
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

JWT_SECRET=please-change-this-jwt-secret-at-least-32-chars
JWT_EXPIRATION_SECONDS=86400

REDIS_CACHE_ENABLED=true
REDIS_DASHBOARD_TTL_SECONDS=30
REDIS_AUTH_SESSION_ENABLED=true

RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_REGISTER_PER_FIVE_MINUTES=5
RATE_LIMIT_AI_PER_MINUTE=30

UPLOAD_MAX_FILE_SIZE=20MB
UPLOAD_MAX_REQUEST_SIZE=20MB
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENABLED=true
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_BUCKET=campus-files

RABBITMQ_ENABLED=true
RABBITMQ_USERNAME=campus
RABBITMQ_PASSWORD=campus_mq_pwd
RABBITMQ_VIRTUAL_HOST=/
RABBITMQ_NOTIFICATION_EXCHANGE=campus.notification.exchange
RABBITMQ_NOTIFICATION_QUEUE=campus.notification.queue
RABBITMQ_NOTIFICATION_ROUTING_KEY=campus.notification.created

OPENAPI_ENABLED=true
SWAGGER_UI_ENABLED=true

MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,prometheus
MANAGEMENT_HEALTH_SHOW_DETAILS=never

AI_ENABLED=false
AI_API_URL=
AI_API_KEY=
AI_MODEL=gpt-3.5-turbo
AI_REQUIRE_API_KEY=true
AI_TIMEOUT_SECONDS=20
