MYSQL_DATABASE=campus_service
MYSQL_USER=campus
MYSQL_PASSWORD=campus_pwd
MYSQL_ROOT_PASSWORD=root_pwd

SPRING_PROFILES_ACTIVE=prod

BACKEND_PORT=8080
NGINX_PORT=80
NGINX_HTML_DIR=./deploy/html
MYSQL_PORT=3306
REDIS_PORT=6379

JWT_SECRET=please-change-this-jwt-secret-at-least-32-chars
JWT_EXPIRATION_SECONDS=86400

REDIS_CACHE_ENABLED=true
REDIS_DASHBOARD_TTL_SECONDS=30
REDIS_AUTH_SESSION_ENABLED=true

OPENAPI_ENABLED=true
SWAGGER_UI_ENABLED=true

AI_ENABLED=false
AI_API_URL=
AI_API_KEY=
AI_MODEL=gpt-3.5-turbo
AI_REQUIRE_API_KEY=true
AI_TIMEOUT_SECONDS=20
